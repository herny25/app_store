{
  "expo": {
    "name": "RetailFlow",
    "slug": "retailflow",
    "version": "1.0.0",
    "icon": "./assets/tienda-de-aplicaciones.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "retailflow",
    "splash": {
      "image": "./assets/tienda-de-aplicaciones.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4FFF"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-sqlite", { "enableFTS": true }]
    ],
    "android": {
      "package": "com.retailflow.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/tienda-de-aplicaciones.png",
        "backgroundColor": "#1B4FFF"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.retailflow.app"
    },
    "extra": {
      "eas": {
        "projectId": "5612a418-b223-4d92-b9a0-e37888159604"
      }
    }
  }
}
